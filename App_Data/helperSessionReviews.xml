<?xml version="1.0" encoding="utf-8"?>
<helperSessionReviews version="1">
  <!--
    One row per raw teaching/help audit log reviewed by an admin.
    logId         = source audit entry id from UnvAdminAudit.xml
    helperId      = helper being reviewed
    helperEmail   = helper email for convenience
    courseId      = resolved microcourse id
    courseTitle   = human-readable title
    scope         = Teaching | Help
    loggedUtc     = original helper log timestamp
    status        = Pending | Verified | Questioned
    adminNote     = note shown back to helper/admin
    reviewedUtc   = last review time
  -->
</helperSessionReviews>