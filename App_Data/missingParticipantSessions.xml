<?xml version="1.0" encoding="utf-8"?>
<missingParticipantSessions>
  <!--
    Each <missing> entry represents a participant marked as a no-show for a specific session.
    Suggested attributes (matches the “new xml for missing participant sessions” idea):
      eventId        = the event (Cyberfair) id
      sessionId      = the session id
      participantId  = the participant user id
      helperId       = the helper user id who marked the no-show
      tsUtc          = when the no-show was recorded (UTC, ISO 8601 "o" format)
  -->
  <!-- Example row (remove if you want an empty base file):
  <missing eventId="E1"
           sessionId="S1"
           participantId="P123"
           helperId="H45"
           tsUtc="2026-02-23T20:15:00.0000000Z" />
  -->
</missingParticipantSessions>