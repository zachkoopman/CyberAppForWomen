<?xml version="1.0" encoding="utf-8"?>
<auditLog version="1">
  <!--
    FIA University Admin Audit Log
    - Each <entry> is a single action in the system.
    - Attributes:
        id          : unique identifier for the log row
        university  : university key/name this entry belongs to
        role        : Participant | Helper | University Admin | Super Admin
        type        : Sign In | Participant Enroll | Helper Quiz Completion | Session Created | etc.
        timestamp   : ISO 8601 UTC time (e.g., 2025-11-20T02:15:00Z)
        email       : account email associated with the action
        firstName   : first name for quick scanning in UI
    - <details>   : short human-readable description of what happened
  -->
</auditLog>